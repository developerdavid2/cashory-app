{
  "name": "cashory-demo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @cashory-demo/db db:push",
    "db:studio": "turbo -F @cashory-demo/db db:studio",
    "db:generate": "turbo -F @cashory-demo/db db:generate",
    "db:migrate": "turbo -F @cashory-demo/db db:migrate"
  },
  "dependencies": {
    "@cashory-demo/env": "*",
    "@react-native-community/netinfo": "11.5.2",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cashory-demo/config": "*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.2"
}
